<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.ProgramExecutorController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="10.0">
            <children>
                <Label text="Number of PrgStates"><font><Font name="System Bold" size="14.0" /></font></Label>
                <TextField fx:id="numberOfPrgStatesTextField" editable="false" promptText="Number of PrgStates" />

                <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="5.0">
                            <children><Label text="Heap Table" />
                                <TableView fx:id="heapTableView" prefHeight="200.0" prefWidth="200.0">
                                    <columns>
                                        <TableColumn fx:id="addressColumn" prefWidth="100.0" text="Address" />
                                        <TableColumn fx:id="valueColumn" prefWidth="100.0" text="Value" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children><Label text="Output" /><ListView fx:id="outputListView" prefHeight="200.0" prefWidth="200.0" /></children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children><Label text="File Table" /><ListView fx:id="fileTableListView" prefHeight="200.0" prefWidth="200.0" /></children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children><Label text="Barrier Table" />
                                <TableView fx:id="barrierTableView" prefHeight="200.0" prefWidth="200.0">
                                    <columns>
                                        <TableColumn fx:id="barrierAddressColumn" prefWidth="75.0" text="Address" />
                                        <TableColumn fx:id="barrierValueColumn" prefWidth="75.0" text="Value" />
                                        <TableColumn fx:id="barrierListColumn" prefWidth="75.0" text="List" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="5.0">
                            <children><Label text="PrgState Identifiers" />
                                <ListView fx:id="prgStateIdentifiersListView" onMouseClicked="#changeProgramState" prefHeight="200.0" prefWidth="200.0" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children><Label text="Symbol Table" />
                                <TableView fx:id="symbolTableView" prefHeight="200.0" prefWidth="200.0">
                                    <columns>
                                        <TableColumn fx:id="variableNameColumn" prefWidth="100.0" text="Variable Name" />
                                        <TableColumn fx:id="variableValueColumn" prefWidth="100.0" text="Value" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children><Label text="Execution Stack" /><ListView fx:id="executionStackListView" prefHeight="200.0" prefWidth="200.0" /></children>
                        </VBox>
                    </children>
                </HBox>

                <Button fx:id="runOneStepButton" mnemonicParsing="false" onAction="#runOneStep" text="Run One Step">
                    <font><Font size="14.0" /></font>
                </Button>
            </children>
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
        </VBox>
    </children>
</StackPane>